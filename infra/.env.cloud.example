# ============================================
# 云端部署环境变量模板
# 复制为 .env.cloud 并填入真实值（该文件已在 .gitignore 中忽略）
# ============================================

# PostgreSQL
POSTGRES_PASSWORD=<generate-secure-password>

# Keycloak
KEYCLOAK_HOSTNAME=https://your-domain.com
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<generate-secure-password>
KEYCLOAK_REALM=llm-dlp
KEYCLOAK_CLIENT_ID=llm-dlp-web
KEYCLOAK_CLIENT_SECRET=<generate-from-keycloak-admin>

# Active Directory / LDAP (optional — only needed for AD domain auth)
LDAP_ENABLED=false
LDAP_URL=ldap://dc01.company.int:389
LDAP_BIND_DN=CN=svc_keycloak,OU=ServiceAccounts,DC=company,DC=int
LDAP_BIND_CREDENTIALS=<ldap-bind-password>
LDAP_USERS_DN=OU=Users,DC=company,DC=int

# LiteLLM
LITELLM_MASTER_KEY=<generate-secure-key>
LITELLM_SALT_KEY=<generate-secure-salt>
# 对外暴露给用户的 LiteLLM 公开地址（SDK 将用此地址调用 API）
# 需要在 DNS / NPM 中将此域名反代到 litellm 容器（端口 4000）
LITELLM_PUBLIC_URL=https://your-domain.com

# LLM API Key (DeepSeek)
DEEPSEEK_API_KEY=sk-xxx

# MinIO / Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<generate-secure-password>
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<generate-secure-password>

# API Server
APP_SECRET_KEY=<generate-with-openssl-rand-32>
APP_LOG_LEVEL=INFO
CORS_ORIGINS=https://your-domain.com

# ============================================
# 前端构建变量（deploy_web.sh 读取并注入 web-client 构建）
# ============================================

# Keycloak 公网地址 — 浏览器通过此地址访问 Keycloak 进行登录/登出
# ⚠️ 部署前必须将此值改为 Keycloak 在域控 DNS 中分配的域名！
# 通常为 https://<your-domain>/auth （NPM 反代路径）或 https://auth.<your-domain> （独立子域）
# 本地开发默认为 http://localhost:8080，云端部署请填写实际公网地址
VITE_KEYCLOAK_URL=https://your-domain.com/auth
