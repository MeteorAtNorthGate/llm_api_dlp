# Database
DATABASE_URL=postgresql+asyncpg://llmuser:llmpass@localhost:5432/llm_dlp

# Keycloak OIDC
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=llm-dlp
KEYCLOAK_CLIENT_ID=llm-dlp-web
KEYCLOAK_CLIENT_ID_LOCAL=llm-dlp-web-local
KEYCLOAK_CLIENT_SECRET=<generate-from-keycloak>

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-master-key-change-me
LITELLM_PUBLIC_URL=http://llmplatform.company.int

# Default model (seeded on first startup — optional, leave empty to edit via UI)
DEEPSEEK_API_KEY=

# App
APP_SECRET_KEY=<generate-with-openssl-rand-32>
APP_LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:5173

# Active Directory / LDAP (optional — only needed for AD domain auth)
LDAP_ENABLED=false
LDAP_URL=ldap://dc01.company.int:389
LDAP_BIND_DN=CN=svc_keycloak,OU=ServiceAccounts,DC=company,DC=int
LDAP_BIND_CREDENTIALS=change-me
LDAP_USERS_DN=OU=Users,DC=company,DC=int
